# ============================================================
# EscalasPT — Environment Variables Template
# Copy to .env and fill in all required values before starting.
# NEVER commit the .env file to version control.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=gnr_admin
POSTGRES_PASSWORD=             # REQUIRED — strong random password
POSTGRES_DB=gnr_escalas
# POSTGRES_PORT=5432           # Dev only — see docker-compose.override.yml

# App-level DB user (limited privileges, no DELETE on audit_logs)
APP_DB_USER=gnr_app
APP_DB_PASSWORD=               # REQUIRED — strong random password

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=                # REQUIRED — strong random password
# REDIS_PORT=6379              # Dev only

# ── JWT Authentication ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=                # REQUIRED — min 64 hex chars, never share
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── TOTP (2FA) ────────────────────────────────────────────────
TOTP_ISSUER_NAME=EscalasPT
# Required when any user enables TOTP.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=           # Fernet key, base64url-encoded

# ── Application ───────────────────────────────────────────────
APP_NAME=EscalasPT
APP_ENV=production             # development | production
APP_DEBUG=false                # true only for local dev
LOG_LEVEL=info                 # DEBUG | INFO | WARNING | ERROR

# ── CORS ──────────────────────────────────────────────────────
# JSON array — no trailing slashes
CORS_ORIGINS=["https://yourdomain.pt"]

# ── Email (SMTP) ─────────────────────────────────────────────
# Set EMAIL_ENABLED=true after configuring SMTP
EMAIL_ENABLED=false
SMTP_HOST=                     # e.g. mail.yourdomain.pt or localhost
SMTP_PORT=587                  # 587 for STARTTLS, 465 for SSL
SMTP_USER=                     # SMTP login (often the email itself)
SMTP_PASSWORD=                 # SMTP password
SMTP_FROM_EMAIL=               # e.g. noreply@yourdomain.pt
SMTP_FROM_NAME=EscalasPT
SMTP_USE_TLS=true

# ── Web Push (VAPID) ─────────────────────────────────────────
# Generate keys: python -c "from pywebpush import webpush; from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('Public:', v.public_key); print('Private:', v.private_key)"
# Or use: npx web-push generate-vapid-keys
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=              # Base64url-encoded public key
VAPID_PRIVATE_KEY=             # Base64url-encoded private key
VAPID_CLAIMS_EMAIL=            # e.g. admin@yourdomain.pt

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=60/minute

# ── Account Lockout ───────────────────────────────────────────
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
MAX_CONCURRENT_SESSIONS=3

# ── Nginx ─────────────────────────────────────────────────────
NGINX_PORT=80

# ──────────────────────────────────────────────
# Shift Defaults
# ──────────────────────────────────────────────
MIN_REST_HOURS=8

# ──────────────────────────────────────────────
# Nginx
# ──────────────────────────────────────────────
NGINX_PORT=80

# ──────────────────────────────────────────────
# Database URLs (auto-composed in docker-compose)
# Only set manually if running outside Docker
# ──────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://gnr_admin:password@localhost:5432/gnr_escalas
# REDIS_URL=redis://:password@localhost:6379/0
