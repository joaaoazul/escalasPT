# ======================================================
# EscalasPT — Production Environment Variables
# Copy to .env.prod and fill in ALL values before deploy
# ======================================================

# ── App ───────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=WARNING

# ── Database ──────────────────────────────────────────
POSTGRES_USER=escalaspt_user
POSTGRES_PASSWORD=       # Generate: openssl rand -base64 24
POSTGRES_DB=escalaspt

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=          # Generate: openssl rand -base64 24

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=          # Generate: openssl rand -base64 32

# ── TOTP encryption ──────────────────────────────────
TOTP_ENCRYPTION_KEY=     # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── CORS (use your DuckDNS or nip.io domain) ─────────
CORS_ORIGINS=["https://escalaspt.duckdns.org"]

# ── Nginx port (Caddy will reverse-proxy to this) ────
ESCALASPT_PORT=8443

# ── Email (optional) ─────────────────────────────────
EMAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# ── Push Notifications (optional) ────────────────────
PUSH_ENABLED=false
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=
