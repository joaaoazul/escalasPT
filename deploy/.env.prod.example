# ======================================================
# EscalasPT — Production Environment Variables
# Generated by deploy/setup.sh — DO NOT add inline comments
# Docker .env files do NOT support inline comments!
# ======================================================

# ── App ───────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=WARNING

# ── Database ──────────────────────────────────────────
POSTGRES_USER=escalaspt_user
POSTGRES_PASSWORD=GENERATE_ME
POSTGRES_DB=escalaspt

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=GENERATE_ME

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=GENERATE_ME

# ── TOTP encryption (Fernet key) ─────────────────────
TOTP_ENCRYPTION_KEY=GENERATE_ME

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=["https://escalaspt.duckdns.org"]

# ── Nginx port (Caddy will reverse-proxy to this) ────
ESCALASPT_PORT=8443

# ── Email (optional — uncomment and fill to enable) ──
EMAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# ── Push Notifications (optional) ────────────────────
PUSH_ENABLED=false
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=
